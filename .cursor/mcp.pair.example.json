{
  "_comment": "Multi-root pair template — compact stdio only. Optional SSE keys when WebUI/Electron is running.",
  "mcpServers": {
    "is-be-mcp": {
      "command": "node",
      "args": ["mcp-server/dist/compactIndex.js"],
      "cwd": "${workspaceFolder:image-scoring-backend}"
    },
    "is-ui-mcp": {
      "command": "node",
      "args": ["mcp-server/dist/compactIndex.js"],
      "cwd": "${workspaceFolder:image-scoring-gallery}"
    },
    "is-be-live": {
      "_comment": "Optional — WebUI running only",
      "url": "http://127.0.0.1:7860/mcp/sse",
      "headers": {
        "Authorization": "Bearer ${env:IMGSCORE_MCP_TOKEN}"
      }
    },
    "is-ui-live": {
      "_comment": "Optional — Electron dev running only",
      "url": "http://127.0.0.1:9373/mcp/sse",
      "headers": {
        "Authorization": "Bearer ${env:GALLERY_MCP_TOKEN}"
      }
    }
  }
}
