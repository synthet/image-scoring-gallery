{
  "_comment": "Merge into gallery .cursor/mcp.json. Build first: cd mcp-server && npm install && npm run build. Live SSE requires Electron dev (gallery-mcp.lock for port). Do not add is-be-* here — use sibling image-scoring-backend workspace.",
  "mcpServers": {
    "is-ui-router": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/routerIndex.js"]
    },
    "is-ui-local": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/localIndex.js"]
    },
    "is-ui-api": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/apiIndex.js"]
    },
    "is-ui-live": {
      "url": "http://127.0.0.1:9373/mcp/sse",
      "headers": {
        "Authorization": "Bearer ${env:GALLERY_MCP_TOKEN}"
      }
    },
    "is-ui-full": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/index.js"],
      "disabled": true
    }
  }
}
