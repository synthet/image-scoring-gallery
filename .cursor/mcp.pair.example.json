{
  "_comment": "Merge into gallery .cursor/mcp.json (copy from mcp.example.json). Build first: cd mcp-server && npm install && npm run build.",
  "mcpServers": {
    "is-ui-router": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/routerIndex.js"]
    },
    "is-ui-local": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/localIndex.js"]
    },
    "is-ui-api": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp-server/dist/apiIndex.js"]
    },
    "is-ui-live": {
      "url": "http://127.0.0.1:9373/mcp/sse",
      "headers": {
        "Authorization": "Bearer ${env:GALLERY_MCP_TOKEN}"
      }
    }
  }
}
