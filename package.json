{
  "name": "electron-gallery",
  "private": true,
  "version": "7.14.0",
  "description": "Driftara Gallery — desktop app for Vexlum Scoring libraries",
  "author": "Driftara Gallery",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others --success command-electron -n server,vite,electron \"npm run server\" \"vite\" \"npm run dev:electron\"",
    "dev:web": "concurrently --kill-others-on-fail -n server,vite \"npm run server\" \"vite\"",
    "vite:only": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p electron/tsconfig.json && cross-env ELECTRON_IS_DEV=1 electron .",
    "build": "tsc -p electron/tsconfig.json && tsc -b && vite build && electron-packager . --overwrite --platform=win32 --arch=x64 --out=release-builds --prune=true",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "cross-env VITEST=1 vitest",
    "test:run": "cross-env VITEST=1 vitest run",
    "test:coverage": "cross-env VITEST=1 vitest run --coverage",
    "test:db": "cd ../image-scoring-backend && python scripts/setup_test_db.py",
    "generate:api-types": "node scripts/generate-api-types.mjs",
    "prebuild-backup-manifest": "node scripts/prebuild-backup-manifest.mjs",
    "contract:update": "node scripts/sync-api-contract.mjs --update",
    "contract:check": "node scripts/sync-api-contract.mjs --check",
    "contract:diff": "node scripts/sync-api-contract.mjs --diff",
    "contract:check-duplicates": "node scripts/check-contract-duplicate-interfaces.mjs",
    "contract:validate": "node scripts/validate-api-types.mjs",
    "dev:browser": "npm run dev:web",
    "server": "npx tsx server/index.ts",
    "start:browser": "npm run build && node dist-server/index.js",
    "check:type-sync": "node scripts/check-type-sync.mjs",
    "doctor": "node scripts/doctor.mjs",
    "design:check": "node scripts/check-design-tokens.mjs"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "com.electron.gallery",
    "productName": "Driftara Gallery",
    "win": {
      "icon": "public/icon.png",
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ]
  },
  "dependencies": {
    "@synthet/image-scoring-design": "github:synthet/image-scoring-ui#v1.0.0",
    "@types/express": "^5.0.6",
    "electron-is-dev": "^3.0.1",
    "exiftool-vendored": "^35.11.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.563.0",
    "pg": "8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-virtuoso": "^4.18.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.1.0",
    "electron-builder": "24.13.3",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.3"
  }
}
