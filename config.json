{
  "database": {
    "engine": "postgres",
    "provider": "postgres",
    "postgres": {
      "host": "127.0.0.1",
      "port": 5432,
      "database": "image_scoring",
      "user": "postgres",
      "password": "postgres"
    }
  },
  "dev": {
    "url": "http://localhost:5173"
  },
  "api": {
    "url": "http://127.0.0.1:7860"
  },
  "firebird": {
    "path": "../image-scoring-backend/Firebird"
  },
  "paths": {
    "remap_legacy_image_scoring_thumbnails": true,
    "thumbnail_base_dir": "./thumbnails",
    "thumbnail_path_remap": [
      {
        "from": "../image-scoring/thumbnails",
        "to": "./thumbnails"
      },
      {
        "from": "../image-scoring/thumbnails",
        "to": "./thumbnails"
      },
      {
        "from": "/mnt/wsl/path/to/image-scoring/thumbnails",
        "to": "./thumbnails"
      }
    ]
  },
  "selection": {
    "smartCoverEnabled": true
  },
  "lightModeRootFolder": "D:\\Photos"
}